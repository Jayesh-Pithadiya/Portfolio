# Server Configuration
PORT=5000
NODE_ENV=development

# Admin Credentials
ADMIN_EMAIL=jayesh@gmail.com
# Generate hash using: npm run generate-hash yourpassword
ADMIN_PASSWORD_HASH=$2b$12$placeholder_run_npm_generate_hash_to_create_real_hash

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_minimum_32_characters_long_change_in_production
JWT_EXPIRY=30m

# IP Restriction (comma-separated, leave empty to disable)
# Example: ALLOWED_IPS=192.168.1.100,203.0.113.45
ALLOWED_IPS=

# CORS Configuration
CLIENT_URL=http://localhost:5173
